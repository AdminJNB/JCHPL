PORT=5000
NODE_ENV=production

# Prefer DATABASE_URL on Render-hosted deployments.
DATABASE_URL=postgresql://username:password@host:5432/database
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# If you are not using DATABASE_URL, set the individual values below instead.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jchpl_mis
DB_USER=postgres
DB_PASSWORD=change-me

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=24h

# Frontend origin(s) allowed for browser requests. Paths like /login are stripped automatically.
# You can provide a single URL or a comma-separated list.
FRONTEND_URL=https://jchpl-frontend.vercel.app
# Optional legacy alias also supported:
# Frontend_URL=https://jchpl-frontend.vercel.app

# Optional email features
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
